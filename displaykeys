#!/bin/zsh

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
APP_BIN="$ROOT_DIR/build/DisplayKeys.app/Contents/MacOS/DisplayKeys"

if [[ ! -x "$APP_BIN" ]]; then
  echo "build missing; run ./build.sh first" >&2
  exit 1
fi

case "${1:-open}" in
  open)
    open "$ROOT_DIR/build/DisplayKeys.app"
    ;;
  left|right|quit)
    "$APP_BIN" "$1"
    ;;
  *)
    echo "usage: ./displaykeys [open|left|right|quit]" >&2
    exit 2
    ;;
esac
